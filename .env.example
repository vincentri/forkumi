# ============================================================
# DOCKER
# ============================================================
# API_PORT: host port mapped to the API container (default 3001)
# WEB_PORT: host port mapped to the web container (default 3000)
# API_CONTAINER_NAME: Docker container name for the API (default api)
# WEB_CONTAINER_NAME: Docker container name for the web (default web)
# API_PORT=3001
# WEB_PORT=3000
# API_CONTAINER_NAME=api
# WEB_CONTAINER_NAME=web

# ============================================================
# DATABASE
# ============================================================
# DATABASE_URL: connection string used by the app and Prisma Client.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
# Local dev example (Postgres running on your machine):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quantyx"
#
# DIRECT_URL: (optional) direct connection for Prisma migrations/introspection.
# Falls back to DATABASE_URL if not set.
# For external providers with connection pooling (Supabase, Railway, etc.),
# set DATABASE_URL to the pooled URL and DIRECT_URL to the direct/unpooled URL.
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/quantyx"

# ============================================================
# NEXTAUTH  (runs in apps/api on port 3001)
# ============================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3001"  # must match API_PORT if changed

# ============================================================
# APP ENCRYPTION
# ============================================================
# Used to encrypt/decrypt provider secrets stored in the database.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="your-encryption-key-here"

# ============================================================
# SPLIT-APP URLs
# ============================================================
# apps/web (port 3000) calls apps/api (port 3001) for tRPC.
#
# Local dev / docker-compose on laptop:
NEXT_PUBLIC_API_URL="http://localhost:3001"  # must match API_PORT if changed
#
# Production (custom domain) — update both values:
# NEXTAUTH_URL="https://api.yourdomain.com"
# NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
# NEXT_PUBLIC_WEB_URL="https://yourdomain.com"
# NEXTAUTH_COOKIE_DOMAIN=".yourdomain.com"
#
# Note: API_URL is set automatically in docker-compose.yml (http://api:3001)
# for server-side SSR calls inside the container. Do not set it here.

# apps/api reads this in src/proxy.ts to set CORS Access-Control-Allow-Origin for /api/* routes.
NEXT_PUBLIC_WEB_URL="http://localhost:3000"  # must match WEB_PORT if changed

# Production: share the session cookie across both apps on the same root domain.
# NEXTAUTH_COOKIE_DOMAIN=".yourdomain.com"

# ============================================================
# AUTH PROVIDERS
# ============================================================

# --- Credentials (email/password) — default, works out of the box ---
# Default user created by pnpm db:seed: admin@example.com / password

# ============================================================
# FILE STORAGE
# ============================================================
# STORAGE_PROVIDER controls where uploaded files (logos, etc.) are stored.
# The database stores provider-neutral relative paths such as /uploads/logo/file.webp.
# Rendering resolves /uploads and /defaults paths through NEXT_PUBLIC_API_URL locally,
# or NEXT_PUBLIC_STORAGE_BASE_URL when S3/CDN storage is configured.
# Options: "local" (default) | "s3"
#
# Local: files saved to public/uploads/<folder>/ (docker bind-mount) or
# apps/api/public/uploads/<folder>/ (pnpm dev), served at /uploads/<folder>/<filename>
# S3:    uploads and seeded /defaults files are copied to AWS S3 with matching keys,
#        then served via NEXT_PUBLIC_STORAGE_BASE_URL
STORAGE_PROVIDER="local"

# Docker only: when ./public is bind-mounted into the API container, match your host user so
# uploads can write. Mac example: DOCKER_UID=501 DOCKER_GID=20 (from id -u / id -g).
# Linux production with bind mount: often DOCKER_UID=1001 DOCKER_GID=1001 or chown public/ to 1001.
# DOCKER_UID=501
# DOCKER_GID=20

# Required only when STORAGE_PROVIDER=s3
# AWS credentials — use IAM role in production instead of access keys when possible.
# Make uploads/defaults publicly readable with an S3 bucket policy or CloudFront distribution.
# Credentials need s3:PutObject for uploads and seeded default assets.
# AWS_REGION="ap-southeast-1"
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_S3_BUCKET="my-app-uploads"

# Base URL for serving uploaded files (S3 only)
# Default: https://{bucket}.s3.{region}.amazonaws.com
# Use a CloudFront distribution URL for better performance:
# NEXT_PUBLIC_STORAGE_BASE_URL="https://d1234567890.cloudfront.net"

# ============================================================
# USER REGISTRATION
# ============================================================
# User registration: not supported by default.
# Admins create users via the admin panel (/admin/user) or invite links (/admin/user → Invite User).
# To add public registration, add a signup route that calls
# prisma.user.create({ data: { email, password: await bcrypt.hash(pw, 10) } }).
