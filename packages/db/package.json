{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./default-assets": {
      "types": "./src/default-assets.ts",
      "default": "./src/default-assets.ts"
    }
  },
  "scripts": {
    "db:migrate": "dotenv -e ../../.env -- sh -c 'cd ../../apps/api/prisma && prisma migrate dev --name \"${1:-schema_change}\" && prisma generate'",
    "db:migrate:deploy": "dotenv -e ../../.env -- sh -c 'cd ../../apps/api/prisma && prisma migrate deploy'",
    "db:reset": "dotenv -e ../../.env -- sh -c 'cd ../../apps/api/prisma && prisma migrate reset --force && prisma generate'",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:studio": "dotenv -e ../../.env -- sh -c 'cd ../../apps/api/prisma && prisma studio'",
    "db:generate": "prisma generate --schema ../../apps/api/prisma/schema.prisma",
    "postinstall": "PRISMA_GENERATE_SKIP_AUTOINSTALL=true prisma generate --schema ../../apps/api/prisma/schema.prisma",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
