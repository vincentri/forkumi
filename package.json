{
  "name": "Quantyx",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:seed": "pnpm --filter @repo/db db:seed",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "setup": "node scripts/setup.mjs",
    "crud:new": "node scripts/crud-new.mjs",
    "crud:scaffold": "tsx scripts/crud-scaffold.ts",
    "crud:delete": "tsx scripts/crud-delete.ts",
    "dev:reset": "node scripts/dev-reset.mjs"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
