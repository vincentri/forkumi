{
  "name": "Quantyx",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:seed": "pnpm --filter @repo/db db:seed",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "setup": "node scripts/setup.mjs",
    "crud:new": "node scripts/crud-new.mjs",
    "crud:scaffold": "tsx scripts/crud-scaffold.ts",
    "crud:delete": "tsx scripts/crud-delete.ts",
    "dev:reset": "node scripts/dev-reset.mjs"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.19.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=20"
  }
}
