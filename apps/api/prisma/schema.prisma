model Blog {
  id        String   @id @default(cuid())
  slug      String
  title     String
  description String
  content   String
  image     String?
  status    String @default("draft")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("blogs")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  location  String
  location_url String
  phone_number String?
  position  Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("locations")
}

model Slider {
  id        String   @id @default(cuid())
  legend    String?
  title     String
  description String
  image     String
  action    String?
  actionurl String?
  position  Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("sliders")
}

model StaticSection {
  id        String   @id @default(cuid())
  key       String   @unique
  namespace String?
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("static_sections")
}

model Gallery {
  id        String   @id @default(cuid())
  image     String
  position  Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  @@map("galleries")
}
