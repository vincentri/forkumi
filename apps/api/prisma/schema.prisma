generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String?
  roleId          String?          @map("role_id")
  role            Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  sentInvitations UserInvitation[] @relation("InvitationSender")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  permissions String[]         @default([])
  protected   Boolean          @default(false)
  users       User[]
  invitations UserInvitation[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  roleId      String?   @map("role_id")
  role        Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  invitedById String?   @map("invited_by_id")
  invitedBy   User?     @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: SetNull)
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("user_invitations")
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  namespace String?
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model FrontPageSettings {
  id        String   @id @default(cuid())
  key       String
  namespace String?
  locale    String   @default("en")
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([key, locale])
  @@map("front_page_settings")
}

model MarqueeItem {
  id        String   @id @default(cuid())
  text      String
  locale    String   @default("en")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("marquee_items")
}

model WhysubCard {
  id        String   @id @default(cuid())
  icon      String   @default("team")
  color     String   @default("purple")
  heading   String
  paragraph String
  locale    String   @default("en")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("whysub_cards")
}

model CompareCategory {
  id        String   @id @default(cuid())
  name      String
  locale    String   @default("en")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("compare_categories")
}

model CompareCriterion {
  id        String   @id @default(cuid())
  label     String
  cells     String   @default("y,n,l")
  locale    String   @default("en")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("compare_criteria")
}

model Portfolio {
  id        String   @id @default(cuid())
  name      String
  sub       String
  blurbId   String?
  blurbEn   String?
  image     String?
  logoBg    String?
  tags      String?
  url       String?
  igUrl     String?
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([position])
  @@map("portfolios")
}

model Plan {
  id          String        @id @default(cuid())
  name        String
  color       String        @default("purple")
  price       String
  normalPrice String        @map("normal_price")
  best        Boolean       @default(false)
  ctaUrl      String?       @map("cta_url")
  locale      String        @default("en")
  position    Int           @default(0)
  active      Boolean       @default(true)
  features    PlanFeature[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("plans")
}

model PlanFeature {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  text      String
  locale    String   @default("en")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([planId, locale, position])
  @@map("plan_features")
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  locale    String   @default("en")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("faqs")
}

model IndustryItem {
  id        String   @id @default(cuid())
  name      String
  tag       String
  locale    String   @default("en")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("industries")
}

model SectionCard {
  id        String   @id @default(cuid())
  section   String
  color     String   @default("purple")
  heading   String
  paragraph String
  locale    String   @default("en")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([section, locale, position])
  @@map("section_cards")
}

model ProcessPhase {
  id          String   @id @default(cuid())
  title       String
  steps       String
  description String
  locale      String   @default("en")
  position    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("process_phases")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  pkg       String?
  message   String
  locale    String   @default("id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("contact_submissions")
}

model ServiceCategory {
  id        String   @id @default(cuid())
  name      String
  items     String
  tint      String   @default("purple")
  image     String?
  locale    String   @default("en")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("service_categories")
}

model PlanOfInterest {
  id        String   @id @default(cuid())
  name      String
  locale    String   @default("en")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([locale, position])
  @@map("plan_of_interest")
}
